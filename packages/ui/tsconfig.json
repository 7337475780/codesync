{
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "jsx": "preserve",
    "moduleResolution": "bundler",
    "module": "esnext",
    "target": "es2022",
    "lib": ["esnext", "dom", "dom.iterable"],
    "types": ["node"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true
  },
  "include": [
    "src"
  ]
}
